# macOS / logs
.DS_Store
*.log

# transient Seatbelt sandbox profiles written at runtime
.argos_sandbox.sb
.argos_run.sb

# local env (dev keys — never commit)
.env.local
.env*.local
# CLAUDE.md is tracked (dev guide for Claude Code working on Argos) — not ignored.
# AGENTS.md stays ignored: guard against re-adding a root-level dev clone. The product
# reads AGENTS.md from *user* projects; it doesn't belong in this repo's root.
AGENTS.md

# codegraph index
.codegraph

# ignore local .claude state (settings, locks) but DO track shared project skills
.claude/*
!.claude/skills/

# QA verification screenshots (throwaway)
screenshots/

# python
__pycache__/
*.pyc
*.egg-info/
.coverage
.pytest_cache/
.venv/

# PyInstaller arm64 单 binary 产物(打包态,不进 git)
/build/
/dist/
*.spec.bak

#superpowers
.superpowers

#claude
.claude
