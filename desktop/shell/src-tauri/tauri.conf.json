{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Argos",
  "version": "0.1.0",
  "identifier": "app.argos.shell",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Argos",
        "width": 900,
        "height": 650,
        "resizable": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "public.app-category.productivity",
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
