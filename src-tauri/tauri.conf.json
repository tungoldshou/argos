{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Argos",
  "version": "0.1.0",
  "identifier": "ai.nous.hermes.argos",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Argos — Hermes",
        "width": 1440,
        "height": 900,
        "minWidth": 720,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#0b0d14"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
